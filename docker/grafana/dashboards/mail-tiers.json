{
  "id": null,
  "title": "Mail Tiers",
  "uid": "cabal-mail-tiers",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "cabalmail",
    "phase3"
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "TCP probe — IMAP 993",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "probe_success{instance=~\".*:993\"}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "TCP probe — SMTP-IN 25",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "probe_success{instance=~\".*:25\"}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "TCP probe — Submission 465/587",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "min(probe_success{instance=~\".*:(465|587)\"})",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "TLS days to expiry — IMAP 993 (ACM)",
      "description": "Cert is served by the NLB (TLS terminated there) using the ACM-managed *.cabalmail.net cert. Observed via blackbox-tls tcp_tls probe.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{instance=~\".*:993\"} - time()) / 86400",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 4
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "TLS days to expiry — Submission 465 (Let's Encrypt)",
      "description": "Cert is served by the smtp-out container (TLS terminated in-container by Dovecot) using the Let's Encrypt cert managed by the cabal-certbot-renewal Lambda. Observed via blackbox-tls tcp_tls probe.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{instance=~\".*:465\"} - time()) / 86400",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 4
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Probe duration p95 (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "probe_duration_seconds",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      }
    }
  ]
}
